      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "name": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "allergens": {
      "type": "component",
      "component": "shared.allergen",
      "repeatable": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Primero",
        "Segundo ",
        "Postre"
      ]
    }
  }
}
